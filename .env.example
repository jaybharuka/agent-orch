ENVIRONMENT=development

# Security
SECRET_KEY=change-me-in-production

# PostgreSQL
POSTGRES_USER=agentorch
POSTGRES_PASSWORD=agentorch
POSTGRES_DB=agentorch
DATABASE_URL=postgresql+asyncpg://agentorch:agentorch@postgres:5432/agentorch

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ChromaDB  (service name is "chroma" in docker-compose)
CHROMA_URL=http://chroma:8000

# LLM — NVIDIA NIM (primary)
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# LLM — fallback
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
